# =============================================================================
# FamilyFun — Environment variables template
# =============================================================================
# Copy this file to .env.local and fill in the values you need.
# Only VITE_-prefixed variables are exposed to the browser bundle.
#
# Most variables are optional — the app runs with sensible defaults.
# =============================================================================

# --- App ---
# Canonical URL of the site. Used in SEO, Open Graph, Schema.org markup.
VITE_SITE_URL=https://familyfun.pl

# --- Analytics (optional) ---
# Plausible domain for privacy-friendly analytics.
# Leave empty to disable analytics.
VITE_PLAUSIBLE_DOMAIN=

# Google Tag Manager container ID (e.g. GTM-XXXXXX).
# Leave empty to disable.
VITE_GTM_ID=

# --- Backend: Supabase (optional until backend phase) ---
# Find these in your Supabase project: Settings → API.
# While empty, the app uses local storage as a fallback.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Observability (optional) ---
# Sentry DSN for error tracking.
VITE_SENTRY_DSN=

# --- Feature flag overrides (optional) ---
# Accepted values: "true" / "1" to enable, empty / "false" to disable.
# These override src/lib/featureFlags.ts at runtime — useful for staging.
VITE_ENABLE_ONBOARDING=
